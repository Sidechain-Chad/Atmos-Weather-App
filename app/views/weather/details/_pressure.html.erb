<%
  pv = wx_round(weather.current["pressure_msl"])
  pressure_values = hourly_window(weather, "pressure_msl").compact
  trend = pressure_values.size >= 2 ? (pressure_values.last - pressure_values.first) : 0
  category = pv < 1000 ? "Low" : pv > 1020 ? "High" : "Normal"
%>
<div class="detail-hero">
  <div class="detail-hero-val"><%= pv %><span class="unit-lg">hPa</span></div>
  <div class="detail-hero-sub"><%= pressure_trend_label(hourly_window(weather, "pressure_msl")) %> over the last few hours.</div>
</div>

<div class="detail-section">
  <div class="detail-section-hd">BAROMETER</div>
  <div style="display:flex;justify-content:center;padding:10px 0">
    <%= pressure_gauge_detail_svg(weather.current["pressure_msl"]) %>
  </div>
</div>

<div class="detail-section">
  <div class="detail-section-hd">24-HOUR TREND</div>
  <div>
    <%= sparkline_svg(hourly_window(weather, "pressure_msl"), color: "#c8a2ff", fill: "rgba(200,162,255,0.14)") %>
    <div class="axis"><span>Now</span><span>+12h</span><span>+24h</span></div>
  </div>
</div>

<div class="detail-section">
  <div class="detail-section-hd">DETAILS</div>
  <div class="detail-stats">
    <div class="detail-stat"><div class="lbl">Current</div><div class="val"><%= pv %> hPa</div></div>
    <div class="detail-stat"><div class="lbl">Trend (24h)</div><div class="val"><%= trend >= 0 ? "+" : "" %><%= trend.round(1) %> hPa</div><div class="sub"><%= trend.negative? ? "Falling" : "Rising" %></div></div>
    <div class="detail-stat"><div class="lbl">Category</div><div class="val"><%= category %></div></div>
  </div>
</div>
