<%# Atmos — weather is fetched server-side (WeatherService); Stimulus only drives sky/FX animation. %>

<div class="app" data-controller="weather" data-weather-root-url-value="<%= root_path %>">
  <%= render "sky_layers" %>

  <audio data-weather-target="ambientAudio" loop preload="none"></audio>
  <audio data-weather-target="weatherAudio" loop preload="none"></audio>

  <div class="topbar">
    <div class="brand">
      <span class="brand-mark"></span><span>ATMOS</span>
      <button class="sound-toggle" aria-label="Mute ambient sound" title="Sound on"
              data-weather-target="soundToggle" data-action="click->weather#toggleSound">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H3v6h3l5 4V5z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/><path d="M18.5 5.5a9 9 0 0 1 0 13" opacity="0.6"/></svg>
      </button>
    </div>
    <%= render "units_toggle", units: @units %>
  </div>

  <%= render "search_bar" %>

  <%= turbo_frame_tag "weather_dashboard",
        data: { weather_target: "dashboard",
                action: "turbo:before-fetch-request->weather#showSpinner turbo:frame-load->weather#dashboardLoaded" } do %>
    <% if @error %>
      <div class="atmos-alert" role="alert"><span><%= @error %></span></div>
    <% end %>

    <% if @weather %>
      <div data-weather-target="conditionData" hidden
           data-condition="<%= @weather.condition.kind %>"
           data-local-hour="<%= @weather.current["time"].to_s[11, 2].to_i %>"
           data-windy="<%= @weather.current["wind_speed_10m"].to_f > (@units == "imperial" ? 16 : 25) %>"></div>

      <%= render "hero", weather: @weather, location_saved: @location_saved %>
      <%= render "hourly", weather: @weather %>
      <%= render "daily", weather: @weather %>
      <%= render "cards", weather: @weather, units: @units, climate_average: @climate_average %>
      <%= render "my_locations", locations: @saved_locations, current: @weather %>
    <% end %>
  <% end %>

  <div class="atmos-footer">Powered by Open-Meteo</div>
</div>
