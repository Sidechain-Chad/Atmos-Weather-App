<%# Atmos — apple layout. Live data via Open-Meteo (weather_controller.js). %>

<div class="app" data-controller="weather">
  <%# Sky layers inside the controller so Stimulus can find the targets %>
  <div class="sky-bg"      data-weather-target="skyBg"></div>
  <div class="sky-sun"     data-weather-target="skySun"></div>
  <div class="sky-stars"   data-weather-target="skyStars"></div>
  <div class="cloud-overlay"   data-weather-target="cloudOverlay"></div>
  <div class="rain-overlay"    data-weather-target="rainOverlay"></div>
  <div class="snow-overlay"    data-weather-target="snowOverlay"></div>
  <div class="fog-overlay"     data-weather-target="fogOverlay"></div>
  <div class="thunder-overlay" data-weather-target="thunderOverlay"><div class="bolt-wrap"></div></div>
  <div class="hail-overlay"    data-weather-target="hailOverlay"></div>

  <div class="topbar">
    <div class="brand"><span class="brand-mark"></span><span>ATMOS</span></div>
    <div class="units-toggle">
      <button type="button" class="u-btn active" data-units="metric"
              data-action="weather#setUnits" data-weather-target="unitMetric">°C</button>
      <button type="button" class="u-btn" data-units="imperial"
              data-action="weather#setUnits" data-weather-target="unitImperial">°F</button>
    </div>
  </div>

  <%# Search %>
  <div class="search">
    <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="1.8">
      <circle cx="11" cy="11" r="7"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <input class="search-input" type="text" autocomplete="off"
           placeholder="Search for a city"
           data-weather-target="cityInput"
           data-action="input->weather#handleInput keydown->weather#handleKeydown">
    <span class="loader" data-weather-target="spinner" style="display:none"></span>
    <div class="search-results" data-weather-target="searchResults"></div>
  </div>

  <%# Error toast %>
  <div class="atmos-alert" data-weather-target="errorAlert" role="alert" style="display:none">
    <span data-weather-target="errorMsg">Something went wrong</span>
  </div>

  <%# Everything below is rendered by the controller after a successful fetch %>
  <div data-weather-target="hero"   class="hero"></div>
  <div data-weather-target="hourly"></div>
  <div data-weather-target="daily"></div>
  <div data-weather-target="cards"  class="cards"></div>

  <div class="atmos-footer">Powered by Open-Meteo</div>
</div>
